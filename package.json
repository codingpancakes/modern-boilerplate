{
	"name": "serverless-backend",
	"version": "1.0.0",
	"description": "Production-grade serverless backend on Cloudflare Workers (Hono + Neon + WorkOS)",
	"scripts": {
		"build": "tsc && pnpm run docs:generate",
		"watch": "npx tsc -w",
		"migrate": "tsx scripts/migrate.ts",
		"sync-secrets": "tsx scripts/sync-secrets.ts",
		"init-project": "tsx scripts/init-project.ts",
		"db:drop": "tsx scripts/_nuke-schema.ts",
		"db:reset": "pnpm db:drop && rm -rf src/node/db/migrations && pnpm db:generate && pnpm migrate",
		"deploy:staging": "wrangler deploy --env staging",
		"deploy:production": "wrangler deploy --env production",
		"db:generate": "dotenv -e .dev.vars -- drizzle-kit generate:pg",
		"db:introspect": "dotenv -e .dev.vars drizzle-kit introspect:pg",
		"dev": "wrangler dev --local",
		"docs:generate": "node scripts/generate-openapi.js",
		"docs:serve": "node docs/api/serve-docs.js",
		"docs:build": "pnpm docs:generate && pnpm docs:serve",
		"docs:dev": "pnpm docs:generate && pnpm docs:serve",
		"docs:graphql": "open http://localhost:8787/v1/graphql || echo 'Start dev server first: pnpm dev'",
		"lint": "npx @biomejs/biome check src/",
		"lint:fix": "npx @biomejs/biome check --write src/",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:integration:up": "docker compose up -d --wait postgres-test",
		"test:integration:local": "pnpm test:integration:up && pnpm test:integration",
		"check": "pnpm lint && pnpm typecheck && pnpm test:run",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@cloudflare/workers-types": "^4.20260612.1",
		"@graphql-codegen/cli": "^6.3.1",
		"@graphql-codegen/typescript": "^5.0.10",
		"@graphql-codegen/typescript-resolvers": "^5.1.8",
		"@types/graphql-depth-limit": "^1.1.6",
		"@types/node": "24.10.1",
		"@types/pg": "^8.20.0",
		"@vitest/ui": "^4.1.8",
		"dotenv-cli": "^10.0.0",
		"drizzle-kit": "^0.20.18",
		"esbuild": "^0.20.2",
		"glob": "^11.1.0",
		"husky": "^9.1.7",
		"pg": "^8.21.0",
		"tsx": "^4.22.4",
		"typescript": "~5.3.3",
		"vitest": "^4.1.8",
		"wrangler": "^4.100.0"
	},
	"dependencies": {
		"@neondatabase/serverless": "^0.9.5",
		"aws4fetch": "^1.0.20",
		"dataloader": "^2.2.3",
		"dotenv": "^16.6.1",
		"drizzle-orm": "^0.29.5",
		"express": "^4.22.2",
		"graphql": "^16.14.2",
		"graphql-depth-limit": "^1.1.0",
		"graphql-yoga": "^5.21.2",
		"hono": "^4.12.25",
		"jose": "^6.2.3",
		"swagger-jsdoc": "^6.3.0",
		"zod": "^3.25.76"
	},
	"pnpm": {
		"overrides": {
			"fast-xml-parser@>=5.0.0 <5.3.5": ">=5.3.5",
			"shell-quote@<1.8.4": ">=1.8.4"
		}
	}
}
