{
  "name": "serverless-backend",
  "version": "1.0.0",
  "description": "Production-grade serverless backend with AWS CDK",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "migrate": "tsx scripts/migrate.ts",
    "db:drop": "tsx scripts/drop-all-tables.ts",
    "db:reset": "npm run db:drop && rm -rf src/node/db/migrations && npm run db:generate && npm run migrate",
    "deploy:staging": "ENV_FILE=.env.staging tsx scripts/deploy.ts",
    "deploy:production": "ENV_FILE=.env.production tsx scripts/deploy.ts",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate:pg",
    "dev": "tsx local-dev/server.ts",
    "docs:generate": "node scripts/generate-openapi.js",
    "docs:serve": "node docs/serve-docs.js",
    "docs:build": "npm run docs:generate && npm run docs:serve",
    "docs:dev": "npm run docs:generate && npm run docs:serve"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.134",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "20.11.5",
    "@types/swagger-ui-express": "^4.1.8",
    "aws-cdk": "2.133.0",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.20.14",
    "esbuild": "^0.20.1",
    "glob": "^11.0.3",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "~5.3.3"
  },
  "dependencies": {
    "@aws-cdk/aws-apigatewayv2-alpha": "2.114.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-authorizers-alpha": "2.114.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-integrations-alpha": "2.114.1-alpha.0",
    "@aws-lambda-powertools/logger": "^2.25.1",
    "@aws-lambda-powertools/metrics": "^2.0.2",
    "@aws-lambda-powertools/tracer": "^2.25.1",
    "@aws-sdk/client-eventbridge": "^3.873.0",
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/client-secrets-manager": "^3.525.0",
    "@aws-sdk/client-ses": "^3.888.0",
    "@aws-sdk/client-sesv2": "^3.888.0",
    "@aws-sdk/client-sns": "^3.888.0",
    "@aws-sdk/client-sqs": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@neondatabase/serverless": "^0.9.0",
    "@types/uuid": "^10.0.0",
    "@workos-inc/node": "^7.69.1",
    "aws-cdk-lib": "2.133.0",
    "constructs": "^10.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.29.4",
    "express": "^4.18.3",
    "jose": "^6.0.13",
    "openai": "^5.20.3",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
  }
}
