{
  "name": "serverless-backend",
  "version": "1.0.0",
  "description": "Production-grade serverless backend with AWS CDK",
  "scripts": {
    "build": "tsc && pnpm run docs:generate",
    "watch": "npx tsc -w",
    "cdk": "cdk",
    "migrate": "tsx scripts/migrate.ts",
    "sync-secrets": "tsx scripts/sync-secrets.ts",
    "db:drop": "tsx scripts/_nuke-schema.ts",
    "db:reset": "pnpm db:drop && rm -rf src/node/db/migrations && pnpm db:generate && pnpm migrate",
    "deploy:staging": "ENV_FILE=.env.staging tsx scripts/deploy.ts",
    "deploy:production": "ENV_FILE=.env.production tsx scripts/deploy.ts",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate:pg",
    "db:introspect": "dotenv -e .env.local drizzle-kit introspect:pg",
    "dev": "tsx local-dev/server.ts",
    "docs:generate": "node scripts/generate-openapi.js",
    "docs:serve": "node docs/api/serve-docs.js",
    "docs:build": "pnpm docs:generate && pnpm docs:serve",
    "docs:dev": "pnpm docs:generate && pnpm docs:serve",
    "docs:graphql": "open http://localhost:3000/v1/graphql/docs || echo 'Start dev server first: pnpm dev'",
    "lint": "npx @biomejs/biome check src/",
    "lint:fix": "npx @biomejs/biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "check": "pnpm lint && pnpm typecheck && pnpm test:run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.6",
    "@graphql-codegen/typescript-resolvers": "^5.1.4",
    "@types/aws-lambda": "^8.10.134",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/node": "24.10.1",
    "@vitest/ui": "^4.0.15",
    "aws-cdk": "2.1100.2",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.20.14",
    "esbuild": "^0.20.1",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "~5.3.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/aws-lambda": "^4.0.0",
    "@aws-lambda-powertools/logger": "^2.25.1",
    "@aws-lambda-powertools/tracer": "^2.25.1",
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/client-secrets-manager": "^3.525.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@neondatabase/serverless": "^0.9.0",
    "@sentry/node": "^10.29.0",
    "aws-cdk-lib": "2.233.0",
    "constructs": "^10.0.0",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.29.4",
    "express": "^4.18.3",
    "graphql": "^16.12.0",
    "graphql-depth-limit": "^1.1.0",
    "jose": "^6.0.13",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^3.22.4"
  }
}
