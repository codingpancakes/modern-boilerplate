 * /v1/public/endpoint:
 *   post:
 *     tags: [Public]
 *     summary: Public endpoint
 *     description: Public endpoint without authentication
 *     requestBody:
 *       required: true
 *       content:
 *         application/json:
 *           schema:
 *             type: object
 *             properties:
 *               data:
 *                 type: object
 *     responses:
 *       200:
 *         description: Success
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 success:
 *                   type: boolean
 *                   example: true
 *                 data:
 *                   type: object
 *       400:
 *         description: Bad request
 */

// OPTION 1: No authentication (for health checks, public endpoints)
const handlerFn = async (event: APIGatewayProxyEventV2, context: Context) => {
  logger.addContext(context);
  
  logger.info('Public endpoint accessed');

  // For health checks
  return {
    statusCode: 200,
    body: JSON.stringify({
      status: 'ok',
      timestamp: new Date().toISOString(),
      version: 'v1',
    })
  };
};

export const handler = handlerFn;

