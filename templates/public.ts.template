// OPTION 3: Custom validation
// For endpoints that need custom validation logic:
const customHandlerFn = async (event: APIGatewayProxyEventV2, context: Context) => {
  logger.addContext(context);
  
  // Custom validation
  const apiKey = event.headers['x-api-key'];
  if (!apiKey || apiKey !== process.env.PUBLIC_API_KEY) {
    return {
      statusCode: 401,
      body: JSON.stringify({
        success: false,
        error: 'Invalid API key'
      })
    };
  }

  logger.info('Public API accessed with valid key');

  // Your logic here

  // 4. Return result using response helper
  logger.info('Request processed');
  return createSuccessResponse({
    message: 'Replace with actual implementation'
  });
};

export const handler = customHandlerFn;
